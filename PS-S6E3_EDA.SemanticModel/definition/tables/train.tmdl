	column 月费区间 = ```
			
			  SWITCH(
			      TRUE(),
			      train[MonthlyCharges] <= 30, "01 30以下",
			      train[MonthlyCharges] <= 50, "02 31-50",
			      train[MonthlyCharges] <= 70, "03 51-70",
			      train[MonthlyCharges] <= 90, "04 71-90",
			      train[MonthlyCharges] <= 110, "05 91-110",
			      "06 110以上"
			  )
			```
		lineageTag: ad0a7372-f0ea-42a1-983a-fc4339cde52f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 总费用区间 = ```
			
			  SWITCH(
			      TRUE(),
			      train[TotalCharges] <= 1000, "01 1千以下",
			      train[TotalCharges] <= 2000, "02 1千-2千",
			      train[TotalCharges] <= 3000, "03 2千-3千",
			      train[TotalCharges] <= 4000, "04 3千-4千",
			      train[TotalCharges] <= 6000, "05 4千-6千",
			      "06 6千以上"
			  )
			```
		lineageTag: 27725e2b-6a88-4a82-824f-95d8f49c192a
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 老年用户标签 = IF(train[SeniorCitizen] = 1, "老年用户", "非老年用户")
		lineageTag: abe46554-5b22-4179-9521-dfe9373fdff5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 在网阶段 = ```
			
			  SWITCH(
			      TRUE(),
			      train[tenure] <= 6, "01 0-6个月",
			      train[tenure] <= 12, "02 7-12个月",
			      train[tenure] <= 24, "03 13-24个月",
			      train[tenure] <= 48, "04 25-48个月",
			      "05 49-72个月"
			  )
			```
		lineageTag: eaa9f2b8-3f19-485c-85f6-23d0fa1d5c11
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 服务打包数 = ```
			
			  VAR ServiceCount =
			      IF(train[PhoneService] = "Yes", 1, 0) +
			      IF(train[MultipleLines] = "Yes", 1, 0) +
			      IF(train[OnlineSecurity] = "Yes", 1, 0) +
			      IF(train[OnlineBackup] = "Yes", 1, 0) +
			      IF(train[DeviceProtection] = "Yes", 1, 0) +
			      IF(train[TechSupport] = "Yes", 1, 0) +
			      IF(train[StreamingTV] = "Yes", 1, 0) +
			      IF(train[StreamingMovies] = "Yes", 1, 0)
			  RETURN
			      SWITCH(
			          TRUE(),
			          ServiceCount <= 1, "01 0-1项服务",
			          ServiceCount <= 3, "02 2-3项服务",
			          ServiceCount <= 5, "03 4-5项服务",
			          "04 6-8项服务"
			      )
			```
		lineageTag: 05418a6a-ca08-4d3b-9ded-74c2f281439d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 防护画像 = ```
			
			  SWITCH(
			      TRUE(),
			      train[InternetService] = "No", "00 无网络服务",
			      train[OnlineSecurity] = "Yes" && train[TechSupport] = "Yes", "01 完整防护",
			      train[OnlineSecurity] = "Yes" || train[TechSupport] = "Yes", "02 部分防护",
			      "03 缺少防护"
			  )
			```
		lineageTag: 3b25c2e1-8fdf-4efc-8732-a7f0510949f3
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 家庭画像 = ```
			
			  SWITCH(
			      TRUE(),
			      train[Partner] = "No" && train[Dependents] = "No", "01 单身",
			      train[Partner] = "Yes" && train[Dependents] = "No", "02 二人世界",
			      train[Partner] = "Yes" && train[Dependents] = "Yes", "03 家庭型",
			      "04 单身带家属"
			  )
			```
		lineageTag: 5bff1506-a1e8-48bc-ab7a-b4e23355dec3
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 流失标签 = IF(train[Churn] = "Yes", "流失", "留存")

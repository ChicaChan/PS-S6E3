table train
	lineageTag: 8f140ec7-6491-4472-b503-9a07c66c6069

	measure 客户总数 = COUNTROWS(train)
		formatString: 0
		lineageTag: b80a82eb-5f66-4c67-ae13-68513c7302d1

	measure 流失客户数 = CALCULATE(COUNTROWS(train), train[Churn] = "Yes")
		formatString: 0
		lineageTag: c8783c73-18d9-4aea-94c8-4f1682a822f6

	measure 流失率 = DIVIDE([流失客户数], [客户总数], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: a2b6be45-a155-4e2c-bfe3-9eca3d7cda15

	measure 总体流失率 = CALCULATE([流失率], ALL(train))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: cb8a5aed-e98d-4840-83f2-6b0bf6185a48

	measure 相对总体流失差 = [流失率] - [总体流失率]
		formatString: +0.00%;-0.00%;0.00%
		lineageTag: 8ac31545-96f2-40fc-b2f9-5e12209002ff

	measure 客户占比 = DIVIDE([客户总数], CALCULATE([客户总数], ALL(train)), 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 46a2401a-4b21-40eb-8cfa-3af462d6e4a8

	measure 风险收入 = CALCULATE(SUM(train[MonthlyCharges]), train[Churn] = "Yes")
		formatString: "¥"#,0.00;"¥"-#,0.00;"¥"#,0.00
		lineageTag: e30b492f-7351-4942-b1f4-c2eb7acfb7db

		annotation PBI_FormatHint = {"currencyCulture":"zh-CN"}

	measure 流失用户平均在网时长 = CALCULATE(AVERAGE(train[tenure]), train[Churn] = "Yes")
		lineageTag: 3c887e4a-9e9b-4b0a-8a6c-421fd5748b46

		annotation PBI_FormatHint = {"isGeneralNumber":true}


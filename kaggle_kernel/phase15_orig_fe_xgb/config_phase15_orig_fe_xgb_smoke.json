{
  "run_name": "phase15_orig_fe_xgb_smoke",
  "target_col": "Churn",
  "id_col": "id",
  "positive_label": "Yes",
  "negative_label": "No",
  "seed": 42,
  "n_folds": 3,
  "inner_folds": 2,
  "max_te_categories": 500,
  "top_cats_for_ngram": [
    "Contract",
    "InternetService",
    "PaymentMethod",
    "OnlineSecurity"
  ],
  "orig_single_mode": "top_cats",
  "enable_orig_cross": true,
  "enable_pctrank_orig": true,
  "enable_pctrank_churn_gap": true,
  "conditional_rank_group_cols": [
    "InternetService",
    "Contract"
  ],
  "conditional_rank_value_col": "TotalCharges",
  "include_digit_features": true,
  "include_te_mean": true,
  "include_te_stats": true,
  "xgb_params": {
    "n_estimators": 120,
    "learning_rate": 0.05,
    "max_depth": 4,
    "subsample": 0.9,
    "colsample_bytree": 0.9,
    "min_child_weight": 1.0,
    "reg_alpha": 0.0,
    "reg_lambda": 1.0,
    "gamma": 0.0,
    "objective": "binary:logistic",
    "eval_metric": "auc",
    "tree_method": "hist",
    "device": "cpu",
    "random_state": 42,
    "early_stopping_rounds": 20,
    "verbosity": 0
  }
}

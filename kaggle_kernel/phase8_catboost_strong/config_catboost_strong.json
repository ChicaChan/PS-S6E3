{
  "seed": 42,
  "n_folds": 5,
  "inner_folds": 5,
  "max_te_categories": 4000,
  "target_col": "Churn",
  "id_col": "id",
  "positive_label": "Yes",
  "negative_label": "No",
  "orig_data_path": "/kaggle/input/datasets/blastchar/telco-customer-churn/WA_Fn-UseC_-Telco-Customer-Churn.csv",
  "top_cats_for_ngram": [
    "Contract",
    "InternetService",
    "PaymentMethod",
    "OnlineSecurity",
    "TechSupport",
    "PaperlessBilling"
  ],
  "orig_single_mode": "all_categorical",
  "enable_orig_cross": true,
  "enable_pctrank_orig": true,
  "enable_pctrank_churn_gap": true,
  "conditional_rank_group_cols": [
    "InternetService",
    "Contract"
  ],
  "conditional_rank_value_col": "TotalCharges",
  "enable_lgbm": false,
  "enable_catboost": true,
  "lgbm_params": {
    "n_estimators": 20000,
    "learning_rate": 0.02,
    "max_depth": 6,
    "num_leaves": 255,
    "subsample": 0.8,
    "colsample_bytree": 0.8,
    "min_child_samples": 80,
    "reg_alpha": 0.2,
    "reg_lambda": 0.5,
    "objective": "binary",
    "metric": "auc",
    "random_state": 42,
    "verbose": -1
  },
  "cat_params": {
    "loss_function": "Logloss",
    "eval_metric": "AUC",
    "learning_rate": 0.03,
    "depth": 6,
    "l2_leaf_reg": 3.0,
    "n_estimators": 14000,
    "random_seed": 42,
    "verbose": 0,
    "task_type": "GPU",
    "use_best_model": true,
    "od_type": "Iter",
    "od_wait": 300
  }
}
